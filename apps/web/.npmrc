# NPM Configuration for Web workspace

# Increase timeouts for CI/CD
fetch-timeout=600000
fetch-retry-mintimeout=60000
fetch-retry-maxtimeout=120000
fetch-retries=5

# Network settings
maxsockets=10
network-concurrency=3

# Registry
registry=https://registry.npmjs.org/

# Logging
loglevel=verbose
progress=false
