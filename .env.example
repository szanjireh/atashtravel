# ============================================
# ATASH TRAVEL - Environment Configuration
# ============================================

# -------------------- General --------------------
NODE_ENV=development
APP_NAME="Atash Travel"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# -------------------- Frontend (Next.js) --------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LANGUAGE=fa
NEXT_PUBLIC_DEFAULT_CURRENCY=IRR

# -------------------- Backend (NestJS) --------------------
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# -------------------- Database (PostgreSQL) --------------------
DATABASE_URL="postgresql://atashtravel:atashtravel_password@localhost:5432/atashtravel?schema=public"

# For Docker Compose
POSTGRES_USER=atashtravel
POSTGRES_PASSWORD=atashtravel_password
POSTGRES_DB=atashtravel
POSTGRES_PORT=5432

# -------------------- Redis --------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# -------------------- JWT Authentication --------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d

# -------------------- MinIO (S3 Storage) --------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=atashtravel

# Public URL for accessing files
MINIO_PUBLIC_URL=http://localhost:9000

# -------------------- Email (SMTP) --------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="Atash Travel <noreply@atashtravel.com>"

# -------------------- SMS Provider --------------------
SMS_PROVIDER=kavenegar
SMS_API_KEY=your-sms-api-key
SMS_SENDER=10008663

# -------------------- Payment Gateways --------------------

# ZarinPal
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id
ZARINPAL_SANDBOX=true

# Saman Bank
SAMAN_MERCHANT_ID=your-saman-merchant-id
SAMAN_TERMINAL_ID=your-saman-terminal-id

# Mellat Bank
MELLAT_TERMINAL_ID=your-mellat-terminal-id
MELLAT_USERNAME=your-mellat-username
MELLAT_PASSWORD=your-mellat-password

# -------------------- Security --------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Argon2 hashing
HASH_ROUNDS=10

# OTP Configuration
OTP_EXPIRY_MINUTES=2
OTP_MAX_ATTEMPTS=5

# -------------------- File Upload --------------------
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp,gif
ALLOWED_DOCUMENT_TYPES=pdf,doc,docx

# -------------------- Google OAuth (Optional) --------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# -------------------- Analytics --------------------
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_SEARCH_CONSOLE_KEY=your-search-console-verification-key

# -------------------- Monitoring & Logging --------------------
LOG_LEVEL=debug
SENTRY_DSN=

# -------------------- Currency Exchange API --------------------
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest

# -------------------- Background Jobs --------------------
QUEUE_REDIS_URL=redis://localhost:6379

# -------------------- Booking Configuration --------------------
BOOKING_LOCK_TIMEOUT=900
BOOKING_EXPIRY_MINUTES=15

# -------------------- Admin --------------------
ADMIN_EMAIL=admin@atashtravel.com
ADMIN_PASSWORD=change-this-strong-password

# -------------------- Nginx --------------------
NGINX_PORT=80
NGINX_SSL_PORT=443
